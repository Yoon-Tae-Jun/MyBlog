                  "bold": true,
                  "italic": false,
                  "strikethrough": false,
                  "underline": false,
                  "code": false,
                  "color": "default"
                }
              },
              {
                "plain_text": "를 통해 유지보수가 용이한 코드를 작성하려 노력하고 있습니다.",
                "href": null,
                "annotations": {
                  "bold": false,
                  "italic": false,
                  "strikethrough": false,
