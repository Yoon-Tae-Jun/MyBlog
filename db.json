          "has_children": false,
          "bulleted_list_item": {
            "rich_text": [
              {
                "plain_text": "단순 비용 절감을 위해 AWS(User Server)와 NCP(Info Generator)를 혼합 사용했으나, 이를 통해 ",
                "href": null,
