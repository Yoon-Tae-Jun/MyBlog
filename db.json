          "paragraph": {
            "rich_text": [
              {
                "plain_text": "순천향대학교 셔틀버스는 수도권 지하철 1호선 신창역 도착 시간과 연계되어 운행됩니다. 그러나 실시간으로 셔틀버스 도착 시간을 알 수 없어 불편함이 존재했습니다. 따라서 공공 데이터 API를 기반으로 신창역 열차 시간 정보와 셔틀버스 시간을 연계한 웹사이트를 개발했습니다.",
                "href": null,
                "annotations": {
                  "bold": false,
                  "italic": false,
                  "strikethrough": false,
