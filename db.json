        {
          "id": "3426601c-5e93-80c9-ab93-c0ce4743ac8e",
          "type": "bulleted_list_item",
          "has_children": false,
          "bulleted_list_item": {
            "rich_text": [
              {
                "plain_text": "기능 구현에 중점을 두다 보니 코드의 재사용성이나 가독성이 낮았던 점이 아쉬웠습니다. 이후 진행한 프로젝트에서는 ",
                "href": null,
                "annotations": {
                  "bold": false,
                  "italic": false,
                  "strikethrough": false,
                  "underline": false,
                  "code": false,
                  "color": "default"
                }
              },
              {
                "plain_text": "디자인 패턴",
