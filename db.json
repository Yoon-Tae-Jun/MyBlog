            ],
            "color": "default"
          }
        },
        {
          "id": "3426601c-5e93-8047-98cb-ce1a9db35dda",
          "type": "heading_3",
          "has_children": false,
          "heading_3": {
            "rich_text": [
              {
                "plain_text": "1. 코드 구조 및 성능 관련",
                "href": null,
                "annotations": {
                  "bold": true,
                  "italic": false,
                  "strikethrough": false,
